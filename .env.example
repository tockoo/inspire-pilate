# ==========================================================================
# Inspire Pilates — Variables d'environnement
# Copiez ce fichier en `.env.local` et renseignez les valeurs.
# NE JAMAIS committer `.env.local`.
# ==========================================================================

# --- Formulaire de contact (Resend) ---
# Clé API privée Resend (côté serveur uniquement, jamais exposée au navigateur).
RESEND_API_KEY=

# Adresse expéditrice vérifiée sur Resend (ex: contact@inspirepilates.fr)
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Adresse qui reçoit les messages du formulaire de contact
CONTACT_TO_EMAIL=

# --- URL publique du site (SEO, sitemap, Open Graph) ---
NEXT_PUBLIC_SITE_URL=https://www.inspirepilates.fr
